---
import { Underline } from "./animations/underline";
import { DotAnimation } from "./animations/dot-animation";
import { Input } from "./input";
import { AiOutlineFacebook, AiOutlineLinkedin } from "react-icons/ai";
import { FaInstagram } from "react-icons/fa";
---

<footer class="text-footer-foreground bg-footer-background mb-0">
  <div class="max-w-7xl mx-auto px-12 py-16 space-y-12">
    <div class="flex flex-col items-center md:grid grid-cols-2 gap-12">
      <div class="space-y-2">
        <div
          class="text-8xl font-extrabold font-sans scale-y-120 relative w-fit"
        >
          LET&apos;S
          <div
            class="absolute text-2xl text-primary -bottom-0.5 left-8 font-light font-mono whitespace-nowrap tracking-widest"
          >
            FEEL FREE TO
          </div>
        </div>
        <div
          class="text-8xl font-extrabold font-sans scale-y-120 relative w-fit"
        >
          GET IN
          <div
            class="absolute text-2xl text-primary -bottom-0.5 right-4 font-light font-mono whitespace-nowrap tracking-widest"
          >
            REACH US
          </div>
        </div>
        <div
          class="text-8xl font-extrabold font-sans scale-y-120 relative w-fit"
        >
          TOUCH
        </div>
      </div>

      <form
        class="grid grid-cols-2 gap-x-8 gap-y-12"
        action="https://sheetdb.io/api/v1/5ivvxdan051gq"
        method="post"
        id="sheetdb-form"
      >
        <Input
          type="text"
          placeholder="FULL NAME *"
          name="data[fullname]"
          className="border-foreground-tertiary focus:border-footer-foreground col-span-2"
          required
        />
        <Input
          type="email"
          placeholder="EMAIL *"
          name="data[email]"
          className="border-foreground-tertiary focus:border-footer-foreground"
          required
        />
        <Input
          type="tel"
          name="data[phone]"
          placeholder="PHONE *"
          className="border-foreground-tertiary focus:border-footer-foreground"
          inputMode="numeric"
          required
        />
        <Input
          type="text"
          name="data[message]"
          placeholder="MESSAGE *"
          className="border-foreground-tertiary focus:border-footer-foreground col-span-2"
          maxLength={200}
          required
        />
        <div class="col-span-2 flex justify-end -mt-4">
          <button
            type="submit"
            class="p-4 scale-100 hover:scale-110 transition-all duration-300"
          >
            <svg
              width="80"
              height="81"
              viewBox="0 0 80 81"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              class="size-12"
            >
              <path
                d="M36.748 3L74.5398 41.2552L38.2403 77.9948M0.443359 39.7448H74.5398"
                stroke="white"
                stroke-width="6.66667"
                stroke-miterlimit="10"
              ></path>
            </svg>
          </button>
        </div>
      </form>

      <div
        id="form-message"
        class="hidden opacity-0 transform scale-95 translate-y-2 transition-all duration-300 col-span-2 text-center p-4 rounded-xl font-semibold"
      ></div>

      <script>
        const form = document.getElementById("sheetdb-form");
        const messageBox = document.getElementById("form-message");
        let hideTimer = null;

        function popupAndFade(text, variant) {
          if (hideTimer) {
            clearTimeout(hideTimer);
            hideTimer = null;
          }

          messageBox.textContent = text;
          messageBox.classList.remove("bg-green-600", "bg-red-600", "text-white");
          if (variant === "success") {
            messageBox.classList.add("bg-green-600", "text-white");
          } else {
            messageBox.classList.add("bg-red-600", "text-white");
          }

          messageBox.classList.remove("hidden");
          messageBox.classList.add("opacity-0", "scale-95", "translate-y-2");

          requestAnimationFrame(() => {
            messageBox.classList.remove("opacity-0", "scale-95", "translate-y-2");
            messageBox.classList.add("opacity-100", "scale-100", "translate-y-0");
          });

          hideTimer = setTimeout(() => {
            messageBox.classList.remove("opacity-100", "scale-100", "translate-y-0");
            messageBox.classList.add("opacity-0", "translate-y-2");

            const onEnd = (e) => {
              if (e.propertyName === "opacity") {
                messageBox.classList.add("hidden", "scale-95");
                messageBox.removeEventListener("transitionend", onEnd);
              }
            };
            messageBox.addEventListener("transitionend", onEnd);
          }, 5000);
        }

        form.addEventListener("submit", (e) => {
          e.preventDefault();

          const fd = new FormData(form);

          // Enforce message length <= 200
          const message = (fd.get("data[message]") || "").toString();
          if (message.length > 200) {
            popupAndFade("Message must be 200 characters or fewer.", "error");
            return;
          }

          // Preserve leading 0 in phone by forcing text in Sheets (prefix with ')
          const rawPhone = (fd.get("data[phone]") || "").toString().trim();
          if (rawPhone) {
            const phoneForSheet = rawPhone.startsWith("'") ? rawPhone : "'" + rawPhone;
            fd.set("data[phone]", phoneForSheet);
          }

          fetch(form.action, {
            method: "POST",
            body: fd,
          })
            .then((response) => response.json())
            .then(() => {
              popupAndFade("Your message has been sent successfully!", "success");
              form.reset();
            })
            .catch(() => {
              popupAndFade("Oops! Something went wrong. Please try again.", "error");
            });
        });
      </script>
    </div>

    <div class="flex max-md:flex-col w-full justify-between gap-8">
      <div>
        <h3>FOLLOW</h3>
        <div class="flex gap-2">
          <a
            href="https://www.facebook.com/thinkercaregroup"
            target="_blank"
            class="hover:scale-110 transition-all duration-300"
          >
            <AiOutlineFacebook className="size-8" />
          </a>
          <hr class="h-7.5 w-px bg-footer-foreground" />
          <a
            href="https://www.linkedin.com/company/thinkercare-group/"
            target="_blank"
            class="hover:scale-110 transition-all duration-300"
          >
            <AiOutlineLinkedin className="size-8" />
          </a>
          <hr class="h-7.5 w-px bg-footer-foreground" />
          <a
            href="https://www.instagram.com/thinkercaregroup"
            target="_blank"
            class="hover:scale-110 transition-all duration-300"
          >
            <FaInstagram className="size-8 scale-90" />
          </a>
        </div>
      </div>
      <div>
        <h3>HATE CONTACTS FORMS ?</h3>
        <Underline
          bottom="0"
          height="2px"
          background="var(--color-footer-foreground)"
        >
          <a href="mailto:contact@thinkercaregroup.com" target="_blank"
            >CONTACT@THINKERCAREGROUP.COM</a
          >
        </Underline>
      </div>
    </div>

    <div class="flex max-md:flex-col w-full justify-between gap-8">
      <img
        src="/assets/logo.svg"
        alt="THINKERCARE GROUP"
        class="size-20 scale-120"
      />
      <a
        class="hover:underline"
        href="https://www.google.com/maps/place/10+Rue+de+la+Paix,+75002+Paris,+France/@48.866667,2.35,17z/data=!4m6!3m5!1s0x47e671fd10fa77a3:0xea0b16a57270d2e0!8m2!3d48.866667!4d2.35!16s%2Fg%2F11c48t3wgv?entry=ttu&g_ep=EgoyMDI1MDIyNS4wIKXMDSoASAFQAw%3D%3D"
        target="_blank"
      >10 RUE <br /> DE LA PAIX 75002 <br /> PARIS FRANCE</a>
      <a
        class="md:text-center hover:underline"
        href="https://www.google.com/maps/place/Jalan+Munduk,+Tengah+Nomor+2D,+Pererenan,+Mengwi,+Bali,+Indonesia/@-8.5206028,115.2346516,17z/data=!4m6!3m5!1s0x2dd22f25e2884165:0x178753056393958!8m2!3d-8.5206028!4d115.2368403!16s%2Fg%2F1td80kbs?entry=ttu&g_ep=EgoyMDI1MDIyNS4wIKXMDSoASAFQAw%3D%3D"
        target="_blank"
      >
        JALAN MUNDUK, <br /> TENGAH NOMOR 2D, <br /> PERERENAN, MENGWI, <br /> BALI,
        INDONESIA.
      </a>

      <div class="relative">
        <svg
          width="15"
          height="18"
          viewBox="0 0 15 18"
          fill="none"
          class="absolute -top-0 -translate-y-full right-0 size-12"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M14.0909 7.54545C14.0909 12.6364 7.54545 17 7.54545 17C7.54545 17 1 12.6364 1 7.54545C1 5.80949 1.68961 4.14463 2.91712 2.91712C4.14463 1.68961 5.80949 1 7.54545 1C9.28142 1 10.9463 1.68961 12.1738 2.91712C13.4013 4.14463 14.0909 5.80949 14.0909 7.54545Z"
            stroke="white"
            stroke-width="0.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M7.54559 9.72728C8.75057 9.72728 9.72741 8.75045 9.72741 7.54547C9.72741 6.34048 8.75057 5.36365 7.54559 5.36365C6.3406 5.36365 5.36377 6.34048 5.36377 7.54547C5.36377 8.75045 6.3406 9.72728 7.54559 9.72728Z"
            stroke="white"
            stroke-width="0.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <a
          class="md:text-end hover:underline"
          href="https://maps.app.goo.gl/eJqjoaNw13sow3mp8"
          target="_blank"
        >
          32 RUE <br /> BENYOUCEF KHETTAB <br /> EL HARRACH 16000 <br /> ALGERIA
        </a>
      </div>
    </div>
  </div>

  <div class="bg-primary p-2 text-center text-black">
    <DotAnimation client:load text="AND THIS IS JUST THE BEGINNING" />
  </div>
</footer>
