---
import { FadeIn } from "../ui/animations/fade-in";
import { Underline } from "../ui/animations/underline";
import { PlaygroundCarousel } from "./playground-carousel";
import { getPhoneSlides } from "./get-phone-slides";

const slides = getPhoneSlides();
---

<section class="space-y-4 mb-16">
  <div
    class="flex items-start justify-between gap-4 group/underline max-w-7xl mx-auto px-4"
  >
    <h2 class="text-title font-bold text-center font-sans relative">
      <Underline bottom="8px" height="4px"> OUR PLAYGROUND </Underline>
    </h2>
    <svg
      viewBox="0 0 114 110"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="size-title"
    >
      <path
        d="M8 99.9299H103.71V8"
        stroke="black"
        stroke-width="20"
        stroke-miterlimit="10"></path>
      <path
        d="M8 8L101.82 101.81"
        stroke="black"
        stroke-width="20"
        stroke-miterlimit="10"></path>
    </svg>
  </div>
  <div class="bg-background-secondary py-6 lg:py-16">
    <div
      class="gap-8 grid grid-cols-2 items-center max-w-7xl mx-auto p-4 overflow-hidden mask-alpha mask-r-from-95%"
    >
      <div class="text-xl font-light self-center">
        <FadeIn delay={0.2} className="mb-4" client:load>
          ACROSS INDUSTRIES, OUR PORTFOLIO IS BUILT TO SHAPE THE FUTURE OF CARE:
        </FadeIn>
        <FadeIn delay={0.2} className="mb-4" client:load>
          SPORT & HEALTH: HANGAR GYM A SPACE WHERE PERFORMANCE MEETS COMMUNITY
          DERMO-COSMETICS: TOUCHÉ AND BELNCO
        </FadeIn>
        <FadeIn delay={0.2} className="mb-4" client:load>
          ADVANCED FORMULATIONS, DERMATOLOGICAL SCIENCE, AND EMOTIONAL ELEGANCE
        </FadeIn>
        <FadeIn delay={0.2} className="mb-4" client:load>
          TECHNOLOGY: OKADOO RESHAPING RETAIL ANS LOGISTICS THROUGH DIGITAL
          INNOVATION.
        </FadeIn>
        <FadeIn delay={0.2} className="mb-4" client:load>
          TEA & HEALTH: SHAITE WELLNESS RITUALS INSPIRED BY NATURE.
        </FadeIn>
        <FadeIn delay={0.2} className="mb-4" client:load>
          BABYCARE: NOOM CARING SOLUTIONS FOR THE VERY FIRST STAGES OF LIFE.
        </FadeIn>
      </div>
      <PlaygroundCarousel client:load slides={slides} />
    </div>
  </div>
</section>
