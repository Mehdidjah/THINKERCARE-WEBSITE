---
import { SplineScene } from "../ui/splite";
import WireModel from "../ui/wire-model";
import AgendaSection from "./agenda-section.astro";
import { brands, heroWordmark, highlights, marquee, metrics, partners } from "./universe-data";

const contactSplineScene = "https://prod.spline.design/kZDDjO5HuC9GJUM2/scene.splinecode";
const heroPixelRows = [
  ["mustard", "mustard", "green", "mustard", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "mustard"],
  ["mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard"],
  ["green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard", "mustard", "green", "mustard"],
];
---

<div class="hidden md:block">
  <header class="site-header">
    <nav class="site-nav" aria-label="Primary">
      <a href="#main" class="site-logo-link" aria-label="ThinkerCare Group home">
        <img src="/assets/logo.svg" alt="ThinkerCare Group" />
      </a>
      <a href="#brands" class="site-nav-link">Brands</a>
      <a href="#agenda" class="site-nav-link">Scoreboard</a>
      <div class="site-nav-spacer" aria-hidden="true"></div>
      <div class="site-nav-actions">
        <a href="#contact" class="site-nav-secondary">Contact</a>
        <a href="#contact" class="site-nav-cta">
          Get in touch <span aria-hidden="true">↗</span>
        </a>
      </div>
    </nav>
  </header>

  <main id="main" class="mx-auto max-w-[1600px] border-x border-grid bg-background-secondary">
    <section class="border-b border-grid">
      <div class="tc-wordmark-row px-2 py-6">
        <h1 class="tc-wordmark hero-wordmark" aria-label="THINKERCARE,GROUP">
          <span class="hero-wordmark-text" aria-hidden="true">
            <span class="hero-wordmark-brand">
              {heroWordmark.thinkerCare.map((letter, index) => (
                <span class="hero-wordmark-letter" style={`--letter-delay: ${240 + index * 75}ms`}>{letter}</span>
              ))}
              <span class="hero-comma-wrap" aria-hidden="true">
                <span class="hero-comma-greenline"></span>
                <span class="hero-comma-rect hero-comma-rect-1"></span>
                <span class="hero-comma-rect hero-comma-rect-2"></span>
                <span class="hero-comma-rect hero-comma-rect-3"></span>
                <span class="hero-comma-rect hero-comma-rect-4"></span>
                <span class="hero-comma-rect hero-comma-rect-5"></span>
                <svg class="hero-comma-arc" viewBox="0 0 30 28" fill="none" aria-hidden="true">
                  <path fill="#08872B" d="M22.1 20.3C26.9 16.1 29.5 9.3 30 0H13.4C13.3 3.85 12.4 6.8 10.6 8.85C8.7 11 5.8 12 1.7 12H0V27.3H0.8C9.8 27.3 16.9 25 22.1 20.3Z"></path>
                </svg>
                <svg class="hero-comma-static" viewBox="0 0 35 62" fill="none" aria-hidden="true">
                  <path fill="#08872B" d="M34 17H17V34H33.5C33.1 43.3 30.5 50 25.7 54.2C20.6 58.8 13.5 61.1 4.5 61.1H3.7V46H5.4C9.4 46 12.3 44.9 14.2 42.8C15.9 40.8 16.9 37.9 17 34H0V0H34V17Z"></path>
                </svg>
              </span>
            </span>
            <span class="hero-wordmark-group">
              {heroWordmark.group.map((letter, index) => (
                <span class="hero-wordmark-group-letter" style={`--group-delay: ${1355 + index * 75}ms`}>{letter}</span>
              ))}
            </span>
          </span>
          {heroWordmark.scanLinePositions.map((position, index) => (
            <span class="hero-wordmark-scanline" style={`--x: ${position}; --scan-delay: ${50 + index * 75}ms`}></span>
          ))}
        </h1>
      </div>

      <div class="grid border-t border-grid md:grid-cols-[1.34fr_1fr]">
        <div class="hero-video-placeholder min-h-[600px] border-grid md:border-r">
          <img
            src="/assets/hero-corporate-workshop.png"
            alt="ThinkerCare team reviewing product packaging concepts in a bright studio"
            class="absolute inset-0 h-full w-full object-cover"
            decoding="async"
            fetchpriority="high"
          />
          <button type="button" aria-label="Pause hero video" class="absolute bottom-6 right-6 z-10 grid size-14 place-items-center rounded-full bg-black/75 font-sans text-xl font-black text-white transition hover:bg-black">
            ||
          </button>
        </div>

        <div class="grid">
          <div class="border-b border-grid text-base">
            <p class="hero-meta-cell justify-start px-6 py-5 text-left font-mono">
              <span class="hero-meta-indicator" aria-hidden="true"></span>
              <span>in-market and growing</span>
            </p>
          </div>
          <div class="border-b border-grid px-8 py-7">
            <p class="max-w-3xl font-sans text-5xl font-semibold leading-[1.04] tracking-[-0.04em]">
              We transform thoughtful ideas into brands, products, and production systems.
            </p>
          </div>
          <div class="relative min-h-[190px] overflow-hidden border-b border-grid bg-background">
            <div class="absolute inset-0">
              <div class="pixel-band-hero h-full" aria-hidden="true">
                {heroPixelRows.map((row) => (
                  <div class="hero-pixel-row">
                    {row.map((tile) => <span class={`hero-pixel-tile is-${tile}`}></span>)}
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="p-6">
            <a href="#contact" class="big-cta">
              Get in touch <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="ticker border-b border-grid bg-primary text-black" data-ticker>
      <button type="button" class="ticker-pause no-trail" aria-label="Pause ticker" data-ticker-toggle>Pause</button>
      <div class="ticker-track">
        {[...marquee, ...marquee, ...marquee, ...marquee, ...marquee, ...marquee].map((item) => (
          <a href="#contact" class="ticker-item">
            {item} <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>

    <section id="experience" class="border-b border-grid">
      <div class="min-h-[320px] border-b border-grid p-8">
        <h2 class="max-w-6xl font-sans text-8xl font-semibold leading-[0.95] tracking-[-0.06em]">
          ThinkerCare is where care brands become movements
        </h2>
      </div>
      <div class="grid lg:grid-cols-[1.25fr_0.95fr]">
        <div class="grid min-h-[430px] border-grid lg:grid-cols-2 lg:border-r">
          <div class="flex items-end border-grid p-6 lg:border-r">
            <p class="font-mono text-lg text-foreground-secondary">dev.experience()</p>
          </div>
          <div class="flex items-start p-6 lg:items-center">
            <p class="max-w-xl font-sans text-4xl font-semibold leading-[1.08] tracking-[-0.04em]">
              See how ideas move from brand strategy to product design, production, launch, and scale.
            </p>
          </div>
        </div>
        <div class="wire-model-panel min-h-[430px]">
          <WireModel client:visible variant="armillary" />
        </div>
      </div>
    </section>

    <section class="grid border-b border-grid lg:grid-cols-[1.25fr_0.95fr]">
      <div class="wire-model-panel min-h-[620px] border-grid lg:border-r">
        <WireModel client:visible variant="turbine" />
      </div>
      <div class="grid">
        <div class="grid min-h-[270px] grid-cols-2 border-b border-grid">
          <div class="flex items-end border-r border-grid p-6">
            <p class="font-mono text-lg text-foreground-secondary">dev.learn()</p>
          </div>
          <div class="p-6">
            <div class="pixel-band pixel-band-warm h-full"></div>
          </div>
        </div>
        <div class="p-8">
          <p class="max-w-2xl font-sans text-5xl font-semibold leading-[1.04] tracking-[-0.04em]">
            Build bold, forward-thinking brands rooted in their time.
          </p>
        </div>
      </div>
    </section>

    <section class="grid border-b border-grid lg:grid-cols-[1fr_1.45fr]">
      <div class="min-h-[500px] border-grid p-8 lg:border-r">
        <p class="mb-28 font-mono text-lg">dev.connect()</p>
        <h2 class="max-w-2xl font-sans text-6xl font-semibold leading-[1.02] tracking-[-0.05em]">
          Across industries, our portfolio is built to shape the future of care.
        </h2>
      </div>
      <div class="grid grid-cols-2">
        <div class="brand-tile border-r border-b border-grid">
          <span>sport and health</span>
        </div>
        <div class="brand-tile border-b border-grid">
          <span>dermo-cosmetics</span>
        </div>
        <div class="brand-tile border-r border-grid">
          <span>tea and wellness</span>
        </div>
        <div class="brand-tile">
          <span>technology</span>
        </div>
      </div>
    </section>

    <section id="stats" class="border-b border-grid">
      <div class="min-h-[260px] border-b border-grid p-8">
        <h2 class="font-sans text-8xl font-semibold leading-none tracking-[-0.06em]">
          scoreboard/
        </h2>
      </div>
      <div class="grid lg:grid-cols-4">
        {metrics.map((metric) => (
          <article class="metric-card">
            <p class="font-sans text-8xl font-black leading-none tracking-[-0.07em] text-primary">
              {metric.value}
            </p>
            <h3 class="mt-8 font-sans text-3xl font-semibold leading-none tracking-[-0.04em]">
              {metric.label}
            </h3>
            <p class="mt-5 max-w-sm text-lg leading-snug text-foreground-secondary">{metric.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="tracks" class="tc-river-section">
      <div class="tc-river-intro">
        <div class="tc-river-intro-cell">
          <h2>Choose the path that moves care ideas into market</h2>
        </div>
        <div class="tc-river-intro-cell tc-river-intro-blank" aria-hidden="true"></div>
      </div>

      <div class="tc-river-row">
        <div class="tc-river-content">
          <h3>brand.build()</h3>
              <p>
                Join ThinkerCare to design, build, and scale a product with strategy, creative direction, production, and launch support.
              </p>
            </div>
        <div class="tc-river-visual">
          <img src="/assets/river-brand-build.jpeg" alt="Abstract chrome figure moving through translucent ribbons" loading="lazy" />
        </div>
      </div>

      <div class="tc-river-row tc-river-row-reverse">
        <div class="tc-river-content">
          <h3>production.scale()</h3>
          <p>
            Move from prototype to small and medium-scale production with systems for quality, logistics, launch, and market readiness.
          </p>
        </div>
        <div class="tc-river-visual tc-river-carousel-visual">
          <img src="/assets/river-production-scale.jpeg" alt="Chrome abstract form stacked in a bright minimal studio" loading="lazy" />
          <div class="tc-river-caption">.production-floor/<span>▌</span></div>
          <div class="tc-river-arrows">
            <button type="button" aria-label="Previous production image">←</button>
            <button type="button" aria-label="Next production image">→</button>
          </div>
        </div>
      </div>

      <div class="tc-river-row">
        <div class="tc-river-content">
          <h3>partner.equity()</h3>
          <p>
            Bring capital, distribution, product, or technology into a group built around trust, vision, and long-term value.
          </p>
        </div>
        <div class="tc-river-visual tc-river-pixel-visual">
          <div class="tc-river-pixel-band" aria-hidden="true"></div>
          <img src="/assets/river-partner-equity.jpeg" alt="Chrome product system components arranged on a white surface" loading="lazy" />
        </div>
      </div>
    </section>

    <AgendaSection id="agenda" contactHref="#contact" />

    <section class="highlight-section border-b border-grid" id="highlights">
      <div class="pixel-band h-56 border-b border-grid"></div>
      <div class="flex min-h-[270px] items-end border-b border-grid px-8 pb-10 pt-16">
        <h2 class="font-sans text-[clamp(4.5rem,6.4vw,7.2rem)] font-semibold leading-none tracking-[-0.06em]">
          selected-highlights/
        </h2>
      </div>
      <div class="grid bg-background-secondary lg:grid-cols-[0.95fr_1fr]">
        <div class="border-grid lg:border-r">
          {highlights.map((item, index) => (
            <button type="button" class={`session-row highlight-trigger highlight-trigger-${index}`}>
              <span class={`session-stripe stripe-${index}`}></span>
              <span class={`mini-placeholder stripe-${index}`}>
                {item.video ? (
                  <video src={item.video} poster={item.poster} autoplay muted loop playsinline preload="metadata" aria-hidden="true"></video>
                ) : item.poster ? (
                  <img src={item.poster} alt="" loading="lazy" aria-hidden="true" />
                ) : null}
              </span>
              <span>{item.name}</span>
            </button>
          ))}
        </div>
        <div class="highlight-detail p-8">
          <div class="highlight-media relative aspect-video overflow-hidden bg-black">
            {highlights.map((item, index) => (
              <div class={`highlight-media-item highlight-media-item-${index}`}>
                {item.video ? (
                  <video class="highlight-video" controls autoplay muted loop playsinline preload="metadata" poster={item.poster}>
                    <source src={item.video} type={item.type} />
                  </video>
                ) : item.poster ? (
                  <>
                    <img src={item.poster} alt="" class="highlight-video" loading="lazy" />
                    <button type="button" aria-label="Play highlight placeholder" class="absolute left-1/2 top-1/2 grid size-24 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-white/70 text-5xl text-black backdrop-blur">
                      ▶
                    </button>
                  </>
                ) : (
                  <>
                    <div class="wire-model-panel h-full">
                      <WireModel client:visible variant="leadscrew" />
                    </div>
                    <button type="button" aria-label="Play highlight" class="absolute left-1/2 top-1/2 grid size-24 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-white/70 text-5xl text-black backdrop-blur">
                      ▶
                    </button>
                  </>
                )}
              </div>
            ))}
          </div>
          <div class="mt-8 grid grid-cols-[minmax(0,1fr)_auto] items-start gap-6">
            <div class="highlight-copy max-w-4xl">
              {highlights.map((item, index) => (
                <div class={`highlight-copy-item highlight-copy-item-${index}`}>
                  <h3 class="font-sans text-5xl font-semibold leading-[1.02] tracking-[-0.05em]">
                    {item.title}
                  </h3>
                  <p class="mt-5 text-xl leading-snug text-foreground-secondary">
                    {item.body}
                  </p>
                </div>
              ))}
            </div>
            <div class="flex gap-2">
              <button type="button" aria-label="Previous highlight" class="media-nav-button">←</button>
              <button type="button" class="media-nav-button">Next <span aria-hidden="true">→</span></button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="brands" class="portfolio-section border-b border-grid">
      <div class="portfolio-header">
        <p class="portfolio-eyebrow">your-story-starts-here <span aria-hidden="true"></span></p>
        <h2 class="portfolio-title">brands/</h2>
        <p class="portfolio-intro">
          We do not see markets. We see playgrounds where bold ideas meet real-world needs.
        </p>
      </div>

      <div class="portfolio-group">
        <div class="portfolio-group-head">
          <div class="portfolio-group-labels">
            <p class="portfolio-group-title">our brands/</p>
            <p class="portfolio-group-note">Brands we build, own, and scale in-house.</p>
          </div>
          <span class="portfolio-group-count">{brands.length} active systems</span>
        </div>
        <div class="portfolio-logo-grid portfolio-logo-grid-owned">
          {brands.map((brand) => (
            <a href={brand.href} target="_blank" rel="noreferrer" class="portfolio-logo-cell">
              <img src={brand.image} alt={brand.name} />
            </a>
          ))}
        </div>
      </div>

      <div class="portfolio-group">
        <div class="portfolio-group-head">
          <div class="portfolio-group-labels">
            <p class="portfolio-group-title">equity partner brands/</p>
            <p class="portfolio-group-note">Long-term partners, separate from the owned portfolio.</p>
          </div>
          <span class="portfolio-group-count">{partners.length} partners</span>
        </div>
        <div class="portfolio-logo-grid portfolio-partner-grid">
          {partners.map((partner) => (
            <a href={partner.href} target="_blank" rel="noreferrer" class="portfolio-logo-cell">
              <img src={partner.image} alt={partner.name} />
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="grid border-b border-grid lg:grid-cols-[1.2fr_0.8fr]">
      <div class="wire-model-panel min-h-[520px] border-grid lg:border-r">
        <WireModel client:visible variant="planetary" />
      </div>
      <div class="flex flex-col justify-between p-8">
        <p class="font-mono text-lg">attendee:</p>
        <blockquote class="mt-20 font-sans text-5xl font-semibold leading-[1.08] tracking-[-0.04em]">
          Caring is what we do best.
        </blockquote>
        <p class="mt-8 max-w-xl text-xl leading-snug text-foreground-secondary">
          Our shared vision places humanity at the center, creating brands that are useful, desirable, and responsible.
        </p>
      </div>
    </section>

    <section id="contact" class="grid border-b border-grid lg:grid-cols-[1fr_1fr]">
      <div class="contact-intro border-grid lg:border-r">
        <div class="contact-model-shell">
          <SplineScene client:visible scene={contactSplineScene} className="contact-spline-scene" backgroundColor="#e9edec" />
        </div>
      </div>
      <form class="grid gap-0 bg-background" action="https://sheetdb.io/api/v1/5ivvxdan051gq" method="post">
        <label class="form-row">
          <span>Full name</span>
          <input type="text" name="data[fullname]" required />
        </label>
        <label class="form-row">
          <span>Email</span>
          <input type="email" name="data[email]" required />
        </label>
        <label class="form-row">
          <span>Phone</span>
          <input type="tel" name="data[phone]" inputmode="numeric" required />
        </label>
        <label class="form-row">
          <span>Message</span>
          <input type="text" name="data[message]" maxlength="200" required />
        </label>
        <div class="p-8">
          <button type="submit" class="big-cta w-full">
            Send message <span aria-hidden="true">↗</span>
          </button>
        </div>
      </form>
    </section>
  </main>

  <footer class="mx-auto max-w-[1600px] overflow-hidden border-x border-b border-grid bg-background-secondary text-foreground">
    <div class="tc-wordmark-row border-b border-grid px-8 py-12">
      <h2 class="tc-wordmark tc-wordmark-footer">
        <span>THINKERCARE</span><span class="tc-wordmark-accent">,</span><span>GROUP</span>
      </h2>
    </div>
    <div class="grid min-h-24 border-b border-grid lg:grid-cols-[1.24fr_0.72fr_0.94fr_0.86fr_0.88fr_0.84fr_minmax(0,1.72fr)]">
      <p class="footer-cell font-mono text-foreground-secondary">© 2026 THINKERCARE GROUP.</p>
      <a href="#brands" class="footer-cell">Brands</a>
      <a href="#agenda" class="footer-cell">Scoreboard</a>
      <a href="#contact" class="footer-cell">Contact</a>
      <a href="https://www.instagram.com/thinkercaregroup" target="_blank" rel="noreferrer" class="footer-cell">Instagram</a>
      <a href="https://www.linkedin.com/company/thinkercare-group/" target="_blank" rel="noreferrer" class="footer-cell">LinkedIn</a>
      <a href="mailto:contact@thinkercaregroup.com" class="footer-cell footer-cell-contact justify-between gap-4 font-mono">
        <span>contact@thinkercaregroup.com</span> <span aria-hidden="true">↗</span>
      </a>
    </div>
    <a href="#contact" class="footer-command no-trail">
      echo "start-a-project" &gt;&gt; thinkercare/group <span aria-hidden="true">↗</span>
    </a>
  </footer>

  <script is:inline>
    (() => {
      const fitHeroWordmarks = () => {
        const wordmarks = document.querySelectorAll(".hero-wordmark");

        wordmarks.forEach((wordmark) => {
          const text = wordmark.querySelector(".hero-wordmark-text");
          if (!text) return;

          const isMobileWordmark = Boolean(wordmark.closest(".mobile-hero-wordmark-row"));
          const edgeReserve = isMobileWordmark
            ? Math.max(10, Math.min(24, wordmark.clientWidth * 0.03))
            : Math.max(56, Math.min(96, wordmark.clientWidth * 0.05));
          const availableWidth = wordmark.clientWidth - edgeReserve;
          if (availableWidth <= 0) return;

          wordmark.style.removeProperty("--hero-wordmark-fit-size");

          const currentSize = Number.parseFloat(getComputedStyle(wordmark).fontSize);
          const textWidth = text.scrollWidth || text.getBoundingClientRect().width;
          if (!currentSize || !textWidth) return;

          const minSize = isMobileWordmark ? 20 : 46;
          const maxSize = isMobileWordmark ? 66 : 260;
          const fittedSize = Math.max(minSize, Math.min(maxSize, currentSize * (availableWidth / textWidth)));
          wordmark.style.setProperty("--hero-wordmark-fit-size", `${fittedSize}px`);
        });
      };

      const scheduleFit = () => window.requestAnimationFrame(fitHeroWordmarks);

      scheduleFit();
      window.addEventListener("resize", scheduleFit, { passive: true });

      if ("ResizeObserver" in window) {
        const observer = new ResizeObserver(scheduleFit);
        document.querySelectorAll(".hero-wordmark").forEach((wordmark) => observer.observe(wordmark));
      }

      if (document.fonts?.ready) {
        document.fonts.ready.then(scheduleFit);
      }
    })();
  </script>
</div>
