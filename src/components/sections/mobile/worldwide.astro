---
import { Typewriter } from "../../ui/animations/typewriter";
import { Highlight } from "../../ui/animations/highlight";
---

<section class="p-4 mb-16">
  <h2 class="text-title-lg font-bold text-center font-sans">
    FROM ZERO TO WORLDWIDE
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-[2fr_3fr] max-w-7xl mx-auto gap-4">
    <div class="flex flex-col justify-between gap-4">
      <div class="text-3xl sm:text-4xl md:text-5xl text-end font-sans mt-4">
        <div>SHAPING</div>
        <div>
          <Highlight client:load>THE FUTURE</Highlight>
        </div>
        <div>OF CARE</div>
        <Highlight client:load>ACROSS</Highlight>
        <div>INDUSTRIES.</div>
      </div>
      <div class="flex justify-between items-end">
        <p class="text-base sm:text-lg font-light min-h-42 min-w-12">
          <Typewriter
            client:load
            delay={15}
            text="EXPANDING\nOUR VISION\nTO EVERY\nCORNER\nOF THE\nWORLD."
          />
        </p>
        <p class="text-base sm:text-lg font-light">©2025</p>
      </div>
    </div>
    <img src="/assets/worldwide.png" alt="WORLDWIDE" class="w-full" />
  </div>
</section>
