---
import DesktopUniverse from "../components/sections/universe-desktop.astro";
import MobileUniverse from "../components/sections/mobile/universe-mobile.astro";
import Cursor from "../components/ui/cursor.astro";
import "../styles/global.css";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="ThinkerCare Group is a creative and production collective based in Algiers that transforms ideas into brands and products."
    />
    <meta property="og:title" content="THINKERCARE GROUP" />
    <meta
      property="og:description"
      content="When thinkers become makers. We design, build, and scale bold brands across care, wellness, food, sport, and technology."
    />
    <title>THINKERCARE GROUP | when thinkers become makers</title>
  </head>
  <body class="bg-background-secondary text-foreground antialiased">
    <Cursor />
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-primary focus:px-4 focus:py-3 focus:text-black"
    >
      Skip to content
    </a>

    <div id="content">
      <DesktopUniverse />
      <MobileUniverse />
    </div>

    <script is:inline>
      (() => {
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        document.querySelectorAll("[data-ticker]").forEach((ticker) => {
          const button = ticker.querySelector("[data-ticker-toggle]");
          if (!button) return;

          if (reduceMotion) {
            ticker.classList.add("is-paused");
            button.textContent = "Play";
            button.setAttribute("aria-label", "Play ticker");
          }

          button.addEventListener("click", () => {
            const paused = ticker.classList.toggle("is-paused");
            button.textContent = paused ? "Play" : "Pause";
            button.setAttribute("aria-label", paused ? "Play ticker" : "Pause ticker");
          });
        });

        const revealItems = Array.from(
          document.querySelectorAll(
            "main section > *, footer > *, .metric-card, .pass-card, .session-row, .logo-cell, .brand-tile, .form-row, .highlight-detail, .tc-wordmark-row, .ticker"
          )
        );

        revealItems.forEach((item) => {
          if (!(item instanceof HTMLElement) || item.classList.contains("reveal")) return;
          const index = Array.from(item.parentElement?.children || []).indexOf(item);
          item.classList.add("reveal");
          item.style.setProperty("--reveal-delay", `${Math.max(0, index % 6) * 90}ms`);
        });

        if (reduceMotion || !("IntersectionObserver" in window)) {
          revealItems.forEach((item) => item.classList.add("is-visible"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );

        revealItems.forEach((item) => observer.observe(item));
      })();
    </script>
  </body>
</html>
